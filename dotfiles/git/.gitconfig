[user]
	name			= nednella
	email 			= 119449811+nednella@users.noreply.github.com 

[core]
	editor 			= code --new-window --wait 
	excludesfile 	= ~/.gitignore

[init]
	defaultBranch 	= main

[push]
	default 		= current
	autoSetupRemote = true

[pull]
	rebase 			= true

[fetch]
	prune 			= true

[rebase]
	autostash 		= true

[merge]
	conflictStyle 	= zdiff3

[diff]
	algorithm 		= histogram
	colorMoved 		= default
	renames 		= copies

[rerere]
	enabled 		= true

[branch]
	sort 			= -committerdate

[log]
	date 			= iso

[color]
	ui 				= auto

[color "status"]
    added			= green
    changed			= yellow
    untracked		= cyan
    deleted			= red

[color "diff"]
    meta 			= bold cyan

[alias]
	# branch / checkout / switch
	br     			= branch
	brd    			= branch -d
	brD     		= branch -D
	co       		= checkout
	cob      		= checkout -b
	sw				= switch
	swc				= switch -c

	# remote / sync
	sync			= !git pull --rebase --autostash && git push

	# status / diff
	s      			= status
	ss     			= status -sb
	d      			= diff
	ds      		= diff --staged

	# push
	pushf			= push --force-with-lease

	# stage
	a				= add
	aa				= add --all
	ap				= add --patch

	# commit
	cm				= commit -m
	amend			= commit --amend --no-edit
	reword			= commit --amend
	wip				= !git add -A && git commit -m \"chore: wip\"

	# undo / fixup
	unstage			= reset HEAD --
	undo			= reset --soft HEAD~1
	uncm			= reset --mixed HEAD~1

	# stash shortcuts
	stl				= stash list
	sta				= stash --include-untracked
	stp				= stash pop

	# log
	lg				= log --oneline --graph --decorate -20
	lgp				= log --graph --pretty=format:'%C(yellow)%h%Creset %C(cyan)%an%Creset %s %C(green)(%cr)%Creset' --abbrev-commit
	last			= log -1 HEAD --stat
	who				= shortlog -sne

	# discoverability
	aliases			= config --get-regexp ^alias\\.
	